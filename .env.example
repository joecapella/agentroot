# CofounderAgent local .env.example
# Copy this file to `.env` or `.env.local`, then replace the placeholder values.
# The uncommented variables in this top section are the variables this project actually reads.
# The large commented catalog below is a reusable reference for future integrations.
# Never commit real secrets.

#===============================================================================================
# PROJECT-REQUIRED: local database and repo access
#===============================================================================================

# Prisma database URL. SQLite dev path is resolved relative to prisma/schema.prisma.
DATABASE_URL="file:./dev.db"

# Absolute path to the repo the app is allowed to inspect for @file autocomplete and repo tools.
REPO_ROOT=/absolute/path/to/agent-root








# Required for storing BYOK keys (OpenAI, Anthropic, Gemini, etc.) in the UserSecret table.
# Must be 32 random bytes, supplied as 64 hex chars (recommended) or base64 of 32 bytes.
# Generate one with:  openssl rand -hex 32
# DO NOT rotate this without re-encrypting existing UserSecret rows — old ciphertext won't
# decrypt under a new key. Keep it out of git.
APP_ENCRYPTION_KEY=replace-with-output-of-openssl-rand-hex-32

#===============================================================================================
# PROJECT-REQUIRED when using Microsoft Foundry hosted agent routing
#===============================================================================================

# Foundry project endpoint. Get it from `azd env get-values`, Azure AI Foundry project Overview,
# or Azure Portal. Example shape: https://RESOURCE.services.ai.azure.com/api/projects/PROJECT
AZURE_AI_PROJECT_ENDPOINT=https://YOUR-FOUNDRY-RESOURCE.services.ai.azure.com/api/projects/YOUR-PROJECT

# Hosted agent name deployed in Foundry. Must match the /agents/<name>/ segment if you also set
# AGENT_COFOUNDERAGENT_RESPONSES_ENDPOINT below.
COFOUNDER_AGENT_NAME=CofounderAgent

# Optional but recommended after `azd up`: exact hosted-agent Responses endpoint emitted by azd.
# If omitted, the app builds it from AZURE_AI_PROJECT_ENDPOINT + COFOUNDER_AGENT_NAME.
AGENT_COFOUNDERAGENT_RESPONSES_ENDPOINT=https://YOUR-FOUNDRY-RESOURCE.services.ai.azure.com/api/projects/YOUR-PROJECT/agents/CofounderAgent/endpoint/protocols/openai/responses?api-version=2025-11-15-preview

#===============================================================================================
# PROJECT-RECOMMENDED: Azure OpenAI image and voice features
#===============================================================================================

# Azure OpenAI data-plane endpoint used for direct image generation and TTS.
# Example shape: https://YOUR-RESOURCE.openai.azure.com/
AZURE_OPENAI_ENDPOINT=https://YOUR-AZURE-OPENAI-RESOURCE.openai.azure.com/

# Azure OpenAI image deployment. Defaults in code to gpt-image-2-1, but set it explicitly so
# local .env files are self-documenting.
AZURE_AI_IMAGE_DEPLOYMENT=gpt-image-2-1

# Azure OpenAI TTS deployment used by voice features. Defaults in code to tts-hd.
AZURE_AI_TTS_DEPLOYMENT=tts-hd

#===============================================================================================
# PROJECT-OPTIONAL: direct/local model routes and dev helpers
#===============================================================================================

# Server-side Gemini OpenAI-compatible route. Only needed if you route a task to gemini-pro/flash
# via model overrides; browser BYOK Gemini does not need this server env var.
# GEMINI_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/openai
# GEMINI_API_KEY=AIza-your-gemini-key

# Server-side Ollama OpenAI-compatible route. Browser-local Ollama settings can also be stored in
# the UI; this env var is only for server-side direct-provider routing.
# OLLAMA_ENDPOINT=http://127.0.0.1:11434/v1

# Optional GitHub token used by the CI/CD helper surface. Leave commented unless that feature is enabled.
# GITHUB_TOKEN=github_pat_your-token

# Optional routing overrides. Leave commented unless your deployment names differ from defaults.
# LAST_RESORT_LOGICAL=gpt-5.5
# MODEL_DEPLOYMENT_gpt_5_5=gpt-5.5
# MODEL_DEPLOYMENT_deepseek_v4_flash=DeepSeek-V4-Flash
# MODEL_DEPLOYMENT_kimi_k2_6=Kimi-K2.6
# MODEL_DEPLOYMENT_gpt_image_2=gpt-image-2-1

# Local test/dev helper. Normally leave false/commented.
# LOCAL_DEV_MODE=false

# Future escape hatch only. Foundry hosted-agent Responses currently rejects top-level tools,
# so do NOT set true unless a fresh live probe confirms the platform supports it.
# FOUNDRY_RESPONSES_ALLOW_TOOLS=false


# MASTER .env.example — AI apps, MCPs, BYOK providers, tools, and integrations
# Generated: 2026-05-14
#
# IMPORTANT:
# - This is a reference catalog, not a list where every variable is required.
# - Copy only the variables your project actually uses into .env.local/.env.
# - Never commit real secrets. Keep this file as examples/placeholders only.
# - For public/multi-user apps, store raw secrets encrypted or in a vault, and store only secret refs in the DB.
# - Prefer least-privilege tokens, read-only scopes, short expirations, and explicit user approvals for mutations.

#===============================================================================================
# 00 CofounderAgent / local project
#===============================================================================================

# AZURE_AI_PROJECT_ENDPOINT
# Purpose: Azure AI Foundry project endpoint used to discover/invoke hosted project resources.
# Looks like: https://example-resource.services.ai.azure.com/api/projects/example-project
# Usually found: Azure Portal / Azure AI Foundry / az CLI; resource endpoints are on the resource Overview page.
# AZURE_AI_PROJECT_ENDPOINT=

# COFOUNDER_AGENT_NAME
# Purpose: Name of the Foundry hosted agent this app invokes for chat.
# Looks like: CofounderAgent
# Usually found: Your project settings, provider dashboard, local config, or generated secret store reference.
# COFOUNDER_AGENT_NAME=

# DATABASE_URL
# Purpose: Primary application database connection string. For this project SQLite can use file:./dev.db; production usually uses Postgres.
# Looks like: postgresql://user:password@host:5432/db?schema=public
# Usually found: Your project settings, provider dashboard, local config, or generated secret store reference.
# DATABASE_URL=

# REPO_ROOT
# Purpose: Local repository root that file search and repo tools are allowed to inspect.
# Looks like: /home/you/code/my-project
# Usually found: Your project settings, provider dashboard, local config, or generated secret store reference.
# REPO_ROOT=

# AGENT_DEFAULT_PERSONA
# Purpose: Configuration value for this feature; set it only if that provider or feature is enabled.
# Looks like: replace-me
# Usually found: Your project settings, provider dashboard, local config, or generated secret store reference.
# AGENT_DEFAULT_PERSONA=

# AGENT_DEFAULT_TOOLS_MODE
# Purpose: Configuration value for this feature; set it only if that provider or feature is enabled.
# Looks like: replace-me
# Usually found: Your project settings, provider dashboard, local config, or generated secret store reference.
# AGENT_DEFAULT_TOOLS_MODE=

# AGENT_MAX_LOOPS
# Purpose: Quota/cost/safety ceiling used to prevent runaway usage or oversized operations.
# Looks like: replace-me
# Usually found: Your project settings, provider dashboard, local config, or generated secret store reference.
# AGENT_MAX_LOOPS=

# AGENT_TIMEOUT_MS
# Purpose: Maximum time, in milliseconds, to wait before cancelling this provider/tool operation.
# Looks like: 60000
# Usually found: Your project settings, provider dashboard, local config, or generated secret store reference.
# AGENT_TIMEOUT_MS=

# MESSAGE_MAX_CHARS
# Purpose: Quota/cost/safety ceiling used to prevent runaway usage or oversized operations.
# Looks like: replace-me
# Usually found: Your project settings, provider dashboard, local config, or generated secret store reference.
# MESSAGE_MAX_CHARS=

# IMAGE_MAX_BYTES
# Purpose: Quota/cost/safety ceiling used to prevent runaway usage or oversized operations.
# Looks like: 60000
# Usually found: Your project settings, provider dashboard, local config, or generated secret store reference.
# IMAGE_MAX_BYTES=

