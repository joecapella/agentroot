# --- Required ---
# Foundry project endpoint (auto-populated by `azd env get-values`).
AZURE_AI_PROJECT_ENDPOINT=https://plimsoll-resource.services.ai.azure.com/api/projects/plimsoll

# Hosted agent name to invoke for chat.
COFOUNDER_AGENT_NAME=CofounderAgent

# --- Optional ---
# Prisma / SQLite.
DATABASE_URL="file:./dev.db"

# Model deployment overrides (logical name → actual deployment name).
# Env key format: MODEL_DEPLOYMENT_<UPPERCASE_LOGICAL_WITH_UNDERSCORES>
# MODEL_DEPLOYMENT_GPT_5_5=gpt-5.5
# MODEL_DEPLOYMENT_KIMI_K2_6=Kimi-K2.6
# MODEL_DEPLOYMENT_DEEPSEEK_V4_FLASH=DeepSeek-V4-Flash

# --- Direct Provider APIs (bypass Foundry) ---
# Gemini OpenAI-compatible endpoint (e.g. https://generativelanguage.googleapis.com/v1beta/openai)
# GEMINI_ENDPOINT=
# GEMINI_API_KEY=

# Ollama local endpoint (default: http://localhost:11434/v1)
# OLLAMA_ENDPOINT=http://localhost:11434/v1

# Example: route "fast_brainstorm" to Gemini Flash instead of DeepSeek
# MODEL_DEPLOYMENT_GEMINI_FLASH=gemini-2.5-flash-preview-04-17

# Example: route "fast_brainstorm" to local Ollama (llama3.2:3b = fast/light, qwen2.5-coder:7b = code)
# MODEL_DEPLOYMENT_OLLAMA_FAST=llama3.2:3b

# Local repository root for file autocomplete and repo tools.
# Required for /api/files/search; fail-closed if omitted.
# REPO_ROOT=/home/jthomas/code/agent-root
