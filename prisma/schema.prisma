// Prisma schema for CofounderAgent local persistence.
// SQLite for dev — switch to Postgres for hosted later.
// SQLite has no native enum support; we model enums as TEXT with CHECK
// constraints (via @default/values), so this also ports cleanly.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===========================================================================
// MEMORY LAYER — Phase 1: Persistent identity, facts, project workspaces.
// ===========================================================================

// ---------------------------------------------------------------------------
// UserProfile: one row per user — identity, default preferences, and raw JSON
// for extensibility without schema migrations.
// ---------------------------------------------------------------------------
model UserProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  displayName      String   @default("Joseph")
  email            String?
  // Default reasoning/tools/persona saved from Settings UI.
  defaultReasoning String   @default("balanced")
  defaultTools     String   @default("ask")
  defaultPersona   String   @default("auto")
  // Arbitrary key-value config (e.g. preferred editor, OS, timezone).
  preferencesJson  String   @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Fact: something the agent should remember about the user, a project, or a
// constraint.  Auto-extracted from chat + manually curated.
// ---------------------------------------------------------------------------
model Fact {
  id           String    @id @default(cuid())
  userId       String
  // "preference" | "constraint" | "project_knowledge" | "lesson_learned" | "identity"
  category     String    @default("preference")
  // Short label for UI chips (max ~60 chars).
  label        String
  // Full text used when injecting into prompts.
  fullText     String
  // 1–10. 10 = critically important (used to rank what fits in context).
  importance   Int       @default(5)
  // Optional source (conversation id, manual, etc.).
  source       String?
  // When this fact stops being auto-injected (null = never).
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId, category])
  @@index([userId, importance])
}

// ---------------------------------------------------------------------------
// ProjectWorkspace: per-project context — goals, pinned paths, status.
// ---------------------------------------------------------------------------
model ProjectWorkspace {
  id              String   @id @default(cuid())
  userId          String
  slug            String
  displayName     String
  description     String?
  // Ordered goals as JSON string array.
  goalsJson       String   @default("[]")
  // Pinned file/folder paths as JSON string array.
  pinnedPathsJson String   @default("[]")
  // Active repo root for this project (file system path).
  repoRoot        String?
  // "active" | "paused" | "archived"
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, slug])
  @@index([userId, status])
}

// ---------------------------------------------------------------------------
// ToolPolicy: per-user per-tool policy — "autonomous" | "ask" | "readonly" | "blocked"
// ---------------------------------------------------------------------------
model ToolPolicy {
  id        String   @id @default(cuid())
  userId    String
  toolName  String
  policy    String   @default("ask")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, toolName])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// ToolExecution: audit log of every read_file, run_command, write_file, etc.
// ---------------------------------------------------------------------------
model ToolExecution {
  id          String   @id @default(cuid())
  userId      String
  toolName    String
  // "autonomous" | "approved" | "blocked" | "failed" | "pending"
  status      String   @default("pending")
  paramsJson  String
  resultJson  String?
  // Error message if failed.
  error       String?
  createdAt   DateTime @default(now())
  completedAt DateTime?

  @@index([userId, toolName])
  @@index([userId, status])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Approval: explicit human gate before a tool runs.
// ---------------------------------------------------------------------------
model Approval {
  id             String    @id @default(cuid())
  userId         String
  toolName       String
  // Human-readable summary of what will happen.
  description    String
  // Full params for inspection.
  paramsJson     String
  // "pending" | "approved" | "rejected"
  status         String    @default("pending")
  // Link to the ToolExecution row (created when approved).
  toolExecutionId String?
  createdAt      DateTime  @default(now())
  resolvedAt     DateTime?

  @@index([userId, status])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// RollbackSnapshot: stored file copies before destructive edits.
// ---------------------------------------------------------------------------
model RollbackSnapshot {
  id          String   @id @default(cuid())
  userId      String
  conversationId String?
  snapshotDir String
  pathsJson   String   @default("[]")
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
}

// ---------------------------------------------------------------------------
// RetrievalIndex: indexed chunks of repos/docs for semantic/keyword search.
// ---------------------------------------------------------------------------
model RetrievalIndex {
  id          String   @id @default(cuid())
  userId      String
  // Source: repo path, obsidian note path, or "manual".
  source      String
  // File path or note title.
  path        String
  // Which part of the file (line range, heading, etc.)
  chunkId     String
  // Extracted text content.
  content     String
  // Optional: keywords for BM25-style fast filtering.
  keywords    String?
  createdAt   DateTime @default(now())

  @@index([userId, source])
  @@index([userId, path])
}

// ---------------------------------------------------------------------------
// Conversation: a chat thread, tied to a user (single-user for v1).
// ---------------------------------------------------------------------------
model Conversation {
  id             String    @id @default(cuid())
  userId         String
  title          String    @default("New conversation")
  // Optional project tag for per-project filtering in the sidebar.
  project        String?
  // Responses protocol previous_response_id; reused across turns so the
  // hosted agent can chain its own server-side memory.
  previousResponseId String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lastMessageAt  DateTime  @default(now())

  messages Message[]
  tasks    Task[]
  tokenUsages TokenUsage[]
  plans    Plan[]

  @@index([userId, lastMessageAt])
  @@index([project])
}

// ---------------------------------------------------------------------------
// Message: one turn in a Conversation.
// ---------------------------------------------------------------------------
model Message {
  id             String   @id @default(cuid())
  conversationId String
  // Stored as TEXT; one of: "user" | "assistant" | "system" | "tool".
  // (Prisma + SQLite enum portability — see file header.)
  sender         String
  // Persona that produced/received this message ("orchestrator", "code_assistant", ...).
  // Null for user messages without an explicit persona tag.
  persona        String?
  // Plain-text content. Optional because some assistant turns are image-only.
  text           String?
  // Base64-encoded inline image (e.g. GPT-Image-2 output). Capped in code;
  // anything large should move to blob storage in a later phase.
  imageBase64    String?
  // Raw tool calls / tool outputs for replay & debugging.
  toolCallsJson  String?
  // TaskKind chosen by the router for this turn (assistant turns only).
  taskKind       String?
  // Logical model name chosen for this turn.
  modelUsed      String?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tokenUsages  TokenUsage[]

  @@index([conversationId, createdAt])
}

// ---------------------------------------------------------------------------
// Task: an externally-observable side effect requested by the agent
// (open_url, create_todo, etc.) and tracked in the Activity panel.
// ---------------------------------------------------------------------------
model Task {
  id             String   @id @default(cuid())
  // Owner for conversation-less tool tasks. Conversation-attached tasks also
  // set this for simpler local-only scoping and future hosted auth.
  userId         String   @default("joseph")
  conversationId String?
  messageId      String?
  // Tool type: "open_url" | "create_todo" | "generate_image" | "future_tool".
  type           String
  // Lifecycle: "PENDING" | "AWAITING_APPROVAL" | "IN_PROGRESS" | "COMPLETED" | "FAILED" | "CANCELED".
  status         String   @default("PENDING")
  // The tool call's arguments (JSON-serialized).
  paramsJson     String
  // The tool's response payload (JSON-serialized) if it returned.
  resultJson     String?
  // Free-form note for the Activity panel.
  summary        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([userId, createdAt])
  @@index([status])
}

// ===========================================================================
// v2 additions: token tracking, analytics, plans, voice, calendar, cicd
// ===========================================================================

model TokenUsage {
  id                String        @id @default(cuid())
  userId            String
  conversationId    String?
  messageId         String?
  modelUsed         String?
  promptTokens      Int?
  completionTokens  Int?
  totalTokens       Int?
  estimatedCostUsd  Float?
  createdAt         DateTime      @default(now())

  conversation      Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  message           Message?      @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([conversationId])
}

model AnalyticsEvent {
  id          String   @id @default(cuid())
  userId      String
  eventType   String
  payloadJson String   @default("{}")
  createdAt   DateTime @default(now())

  @@index([userId, eventType, createdAt])
}

model Plan {
  id             String     @id @default(cuid())
  userId         String
  conversationId String?
  title          String
  status         String     @default("draft")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  steps          PlanStep[]
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([userId, status])
}

model PlanStep {
  id             String    @id @default(cuid())
  planId         String
  stepNumber     Int
  description    String
  status         String    @default("pending")
  toolName       String?
  toolParamsJson String?
  resultJson     String?
  createdAt      DateTime  @default(now())
  completedAt    DateTime?

  plan           Plan      @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
}

model VoiceJob {
  id          String    @id @default(cuid())
  userId      String
  jobType     String
  status      String    @default("pending")
  inputText   String?
  audioBase64 String?
  error       String?
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([userId, status])
}

model CalendarEvent {
  id          String    @id @default(cuid())
  userId      String
  title       String
  description String?
  startAt     DateTime?
  endAt       DateTime?
  timezone    String    @default("America/Chicago")
  icsContent  String?
  status      String    @default("draft")
  createdAt   DateTime  @default(now())

  @@index([userId, startAt])
}

model CiCdJob {
  id          String    @id @default(cuid())
  userId      String
  provider    String    @default("github")
  repo        String
  workflow    String?
  branch      String    @default("main")
  status      String    @default("pending")
  runUrl      String?
  error       String?
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([userId, createdAt])
}

model PromptVariant {
  id          String   @id @default(cuid())
  persona     String
  variantKey  String
  content     String
  isActive    Boolean  @default(false)
  winRate     Float?
  usageCount  Int      @default(0)
  createdAt   DateTime @default(now())

  @@unique([persona, variantKey])
}

// ===========================================================================
// SETTINGS LAYER — added 2026-05-14.
// Backs the in-app Settings page for things that aren't already covered by
// UserProfile (identity/defaults), ToolPolicy (per-tool perms), or
// ModelRoutingOverride (per-task model routing).
// ===========================================================================

// ---------------------------------------------------------------------------
// UserSecret: encrypted BYOK keys + any other server-side stored credential.
// One row per (userId, provider). Plaintext NEVER leaves this model except
// at the moment of use inside the request handler that needs it.
//
// Storage rules (enforced in src/server/secretsVault.ts):
//   - encryptedValue is AES-256-GCM with the app-level APP_ENCRYPTION_KEY.
//     Format: base64(iv | authTag | ciphertext).
//   - redactedPreview is `<prefix>…<last4>` for UI display only. Never the
//     full secret.
//   - The plaintext is never logged, persisted elsewhere, or returned by
//     any GET endpoint. Reads return only metadata + redactedPreview.
//   - On rotation/replacement, the row is overwritten in place (no
//     historical values retained — minimises blast radius if DB leaks).
// ---------------------------------------------------------------------------
model UserSecret {
  id               String    @id @default(cuid())
  userId           String
  // Stable provider key, e.g. "openai" | "anthropic" | "gemini" |
  // "openrouter" | "azure_openai" | "foundry". Lowercase, snake_case.
  provider         String
  // Optional sub-label so a user could later store multiple keys per
  // provider ("personal" vs "work"). For v1 always "default".
  label            String    @default("default")
  // base64(iv | authTag | ciphertext). NEVER plaintext.
  encryptedValue   String
  // e.g. "sk-…abc1" — safe to render in UI. Generated by the vault.
  redactedPreview  String
  // Optional metadata the user pasted alongside the key (org id, project
  // id, base URL override). Plaintext JSON — these are NOT secrets.
  metadataJson     String    @default("{}")
  // Last time we successfully validated the key against the provider.
  // Null = never tested.
  lastVerifiedAt   DateTime?
  // Last time the encryptedValue itself was written (paste/rotate).
  rotatedAt        DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([userId, provider, label])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// UserSettings: typed top-level settings that drive runtime behaviour.
// These are deliberately NOT in UserProfile.preferencesJson because they
// gate cost / privacy / autonomy — too important to bury in a JSON blob.
// One row per user.
// ---------------------------------------------------------------------------
model UserSettings {
  id                      String   @id @default(cuid())
  userId                  String   @unique

  // --- Cost limits ---------------------------------------------------------
  // Hard caps. The chat route rejects new turns once exceeded, with a
  // clear "limit reached" error. 0 = unlimited (default).
  monthlySpendLimitUsd    Float    @default(0)
  dailySpendLimitUsd      Float    @default(0)
  maxToolCallsPerDay      Int      @default(0)
  maxAgentLoopsPerTurn    Int      @default(25)
  maxImagesPerDay         Int      @default(0)

  // --- Privacy / memory ----------------------------------------------------
  memoryEnabled           Boolean  @default(true)
  factExtractionEnabled   Boolean  @default(true)
  storeToolOutputs        Boolean  @default(true)
  // 0 = retain forever. Otherwise a daily sweeper would delete content
  // older than this.
  dataRetentionDays       Int      @default(0)

  // --- Autonomy ------------------------------------------------------------
  // High-level autonomy. Detailed per-tool policy lives in ToolPolicy.
  // "manual" requires approval for everything; "balanced" matches the
  // ToolPolicy table; "autonomous" treats all "ask" policies as "allowed".
  autonomyLevel           String   @default("balanced")

  // --- Catch-all -----------------------------------------------------------
  // Anything that doesn't deserve its own column yet.
  extraJson               String   @default("{}")

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([userId])
}
